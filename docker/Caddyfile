{
  admin off
}

# For IP-based access (development/testing)
:80 {
  encode zstd gzip

  @static {
    path *.js *.css *.png *.jpg *.svg *.ico *.woff *.woff2
  }
  header @static Cache-Control "public, max-age=31536000, immutable"

  # Sitemap from API 
  handle /sitemap.xml {
    reverse_proxy api:8000
  }
  
  # API endpoints
  @api path /healthz* /events* /venues* /api*
  handle @api {
    uri strip_prefix /api
    reverse_proxy api:8000
  }
  
  # Frontend - reverse proxy to nginx container
  handle {
    reverse_proxy frontend:80
  }
  
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# For domain-based access with SSL (uncomment and update domain when ready)
ingl.events, www.ingl.events {
  encode zstd gzip

  @static {
    path *.js *.css *.png *.jpg *.svg *.ico *.woff *.woff2
  }
  header @static Cache-Control "public, max-age=31536000, immutable"

